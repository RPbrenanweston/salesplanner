# Supabase — copy from Dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://gizjnytrcspwbshscmjb.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<anon public key>

# Server-only — never expose to the client
SUPABASE_SERVICE_ROLE_KEY=<service_role key>

# Auth callback — change to your Vercel domain in production
NEXT_PUBLIC_AUTH_CALLBACK_URL=http://localhost:3000/auth/callback

# Run in Supabase SQL Editor: SELECT id FROM planner_apps WHERE slug = 'sales-planner';
SALES_PLANNER_APP_ID=<uuid from planner_apps>
