VITE_SUPABASE_URL=your-project-url
VITE_SUPABASE_ANON_KEY=your-anon-key

# Gmail OAuth (US-022)
VITE_GMAIL_CLIENT_ID=your-google-oauth-client-id
VITE_GMAIL_REDIRECT_URI=http://localhost:3000/oauth/gmail/callback

# Outlook OAuth (US-023)
VITE_OUTLOOK_CLIENT_ID=your-microsoft-oauth-client-id
VITE_OUTLOOK_REDIRECT_URI=http://localhost:3000/oauth/outlook/callback

# Google Calendar OAuth (US-027)
VITE_GOOGLE_CALENDAR_CLIENT_ID=your-google-oauth-client-id
VITE_GOOGLE_CALENDAR_REDIRECT_URI=http://localhost:3000/oauth/google-calendar/callback

# Outlook Calendar OAuth (US-028)
VITE_OUTLOOK_CALENDAR_CLIENT_ID=your-microsoft-oauth-client-id
VITE_OUTLOOK_CALENDAR_REDIRECT_URI=http://localhost:3000/oauth/outlook-calendar/callback

# Salesforce OAuth (US-031)
VITE_SALESFORCE_CLIENT_ID=your-salesforce-connected-app-client-id
VITE_SALESFORCE_REDIRECT_URI=http://localhost:3000/oauth/salesforce/callback

# Stripe (US-043)
VITE_STRIPE_PUBLISHABLE_KEY=your-stripe-publishable-key

# Sentry (FIX-006) — error monitoring
# Get your DSN from https://sentry.io → Project Settings → Client Keys
VITE_SENTRY_DSN=
