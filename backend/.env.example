# Backend Environment Configuration
# Copy this file to .env and fill in your actual values

# CORS Configuration
# Comma-separated list of allowed origins for CORS
# Development: http://localhost:3000,http://localhost:5173
# Production: Add your Railway frontend domain (e.g., https://your-app.up.railway.app)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# Database Configuration
# Railway will automatically provide this when you provision a Postgres database
# Format: postgresql://user:password@host:port/database
DATABASE_URL=postgresql://user:password@localhost:5432/sourcing

# IMPORTANT: Never commit .env file to git!
# Add .env to .gitignore
